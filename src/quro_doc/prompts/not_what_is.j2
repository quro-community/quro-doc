    "intent_id": "pricing.free-trial",
    "question": "What is the free trial period for the subscription?",
    "reason": "appears not to answer because the document mentions Pro and Basic plans but does not mention any free trial offer."
  },
  {
    "intent_id": "features.refund-policy",
    "question": "What is the refund policy for paid plans?",
    "reason": "appears not to answer because the document describes download limits but does not discuss refunds or cancellations."
  }
]

