{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScoringConfig",
  "type": "object",
  "required": ["scorers"],
  "properties": {
    "scorers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "weight"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["vector", "tag", "intent"]
          },
          "weight": {
            "type": "number",
            "minimum": 0.0
          },
          "required": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}