#!/usr/bin/env python3
"""CLI tool: add a document to quro-doc.

Usage:
  quro-add-doc --body "My doc content" --topic design --tags "arch,design"
  quro-add-doc --file /path/to/doc.txt --topic decision
  quro-add-doc --body "Hello" --doc-id my-custom-id
"""

import sys
import os
import json
import argparse

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "src"))

from quro_doc.api import quro_doc_add


def main():
    parser = argparse.ArgumentParser(description="Add a document to quro-doc")
    parser.add_argument("--body", help="Document body text")
    parser.add_argument("--file", help="Read body from file")
    parser.add_argument("--doc-id", help="Optional custom document ID (idempotency)")
    parser.add_argument("--topic", choices=["arch", "dataflow", "database", "design", "decision", "fact"], help="Document topic")
    parser.add_argument("--intent", help="Document intent")
    parser.add_argument("--tags", help="Comma-separated tags")
    parser.add_argument("--source-type", choices=["human", "llm", "system"], default="human", help="Source type")
    parser.add_argument("--source-agent", default="cli", help="Source agent name")
    parser.add_argument("--thread-id", help="Thread/grouping ID")
    parser.add_argument("--importance", type=float, default=0.5, help="Importance 0-1")
    parser.add_argument("--json", help="Full payload as JSON string")
    args = parser.parse_args()

    if args.json:
        payload = json.loads(args.json)
    else:
        body = args.body
        if args.file:
            with open(args.file, "r", encoding="utf-8") as f:
                body = f.read()
        if not body:
            parser.error("Either --body, --file, or --json is required")

        tags = args.tags.split(",") if args.tags else []
        payload = {
            "body": body,
            "topic": args.topic,
            "intent": args.intent,
            "tags": tags,
            "source": {"type": args.source_type, "agent": args.source_agent},
        }
        if args.doc_id:
            payload["doc_id"] = args.doc_id
        if args.thread_id:
            payload.setdefault("metadata", {})["thread_id"] = args.thread_id
        if args.importance is not None:
            payload.setdefault("metadata", {})["importance"] = args.importance

    result = quro_doc_add(payload)
    print(json.dumps(result, indent=2, ensure_ascii=False))
    if result.get("status") == "error":
        sys.exit(1)


if __name__ == "__main__":
    main()
