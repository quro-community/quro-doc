# Quro-Doc configuration example

# Storage root (MUST be .quro_context/docs for prototype)
QURO_STORAGE_ROOT=.quro_context/docs

# Python env (reference)
PYTHON_BIN=.quro-doc/bin/python

# Models (names or connector strings)
EMBEDDING_MODEL=llama/embeddinggemma
EMBEDDING_API_URL=http://localhost:20128/v1/embeddings

# Queue backend (redis recommended for MVP)
QUEUE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

# MCP API key for access control (rotate in prod)
MCP_API_KEY=changeme

# Logging and runtime
LOG_LEVEL=INFO

# Vector store config
VECTOR_STORE_TYPE=fs
VECTOR_STORE_NAMESPACE=default
VECTOR_STORE_PATH=${QURO_STORAGE_ROOT}/index

# Query pipeline toggles
QUERY_NEIGHBOR_EXPANSION=false
QUERY_SMALL_TOP_K=50
QUERY_FINAL_TOP_K=10

# ── Scoring System (feature-gated, protocol-driven) ──
QUERY_USE_SCORING=true
QUERY_SCORER_WEIGHTS=[{"name":"vector","weight":1.0,"required":true},{"name":"tag","weight":0.3}]

# ── Reranker (cross-encoder, optional) ──
QUERY_USE_RERANKER=false
RERANK_MODEL=gpustack/bge-reranker-v2-m3
RERANK_API_URL=http://localhost:8002/v1/rerank
RERANK_TOP_K=20

# ── Standard View (query-time context compilation) ──
STANDARD_VIEW_ENABLED=true
STANDARD_VIEW_SECTIONS=["Goal","Summary","Architecture","Dir Structure","DataFlow","Files"]
STANDARD_VIEW_PLANNER_STRATEGY=heuristic
STANDARD_VIEW_MAX_SECTIONS=5
STANDARD_VIEW_MIN_EVIDENCE_PER_SECTION=1
STANDARD_VIEW_MAX_EVIDENCE_PER_SECTION=5
STANDARD_VIEW_ENABLE_SUMMARIZATION=false
STANDARD_VIEW_TOKEN_BUDGET=4096

# ── Logging ──
QURO_LOG_DIR=.quro_context/logs/quro-docs

# ── View Layer (evidence orchestration runtime) ──
VIEW_ENABLED=true
VIEW_NAME=standard-view
VIEW_SOURCES=["raw","qa_cache"]
VIEW_ENABLE_DISTILL_SOURCE=false
VIEW_SCORER_WEIGHTS=[{"name":"semantic_similarity","weight":1.0,"required":true},{"name":"source_priority","weight":0.2},{"name":"token_penalty","weight":-0.1}]
VIEW_PRUNER_STRATEGY=mmr
VIEW_TOP_K=12
VIEW_MAX_TOKENS=4096
VIEW_MMR_LAMBDA=0.5
VIEW_QA_SHORTCUT_ENABLED=false
VIEW_QA_SHORTCUT_MIN_CONFIDENCE=0.9

# ── Trace & Artifact System ──
QURO_ARTIFACT_STORE_ENABLED=false
QURO_ARTIFACT_FEATURE_WEIGHT=0.0
QURO_TRACE_RETENTION_DAYS=90
QURO_HOT_DOC_SCAN_INTERVAL_MINUTES=360

# Other toggles
ENABLE_HAYSTACK=true
